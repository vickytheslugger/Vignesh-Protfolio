# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local — it is blocked by .gitignore.

# Supabase (get from: https://supabase.com/dashboard → project → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API Key
# IMPORTANT: Do NOT prefix with VITE_ — this must NOT be in the client bundle.
# Use this only in a server-side proxy function (e.g. /api/gemini route).
# GEMINI_API_KEY=your-gemini-key-here
